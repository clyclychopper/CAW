local mmTilePool    = {}
local mmActiveTiles = {}
local MM_POOL_MAX   = 400

local function acquireTile()
    if #mmTilePool > 0 then
        local t = table.remove(mmTilePool)
        t.Visible = true; return t
    end
    local t = Instance.new("Frame")
    t.BorderSizePixel = 0; t.ZIndex = 8; t.Parent = mmCanvas
    return t
end

local function releaseTile(t)
    t.Visible = false
    if #mmTilePool < MM_POOL_MAX then
        table.insert(mmTilePool, t)
    else
        t:Destroy()
    end
end

local COL_READY   = Color3.fromRGB(80,  215, 135)
local COL_GROWING = Color3.fromRGB(60,  190, 210)
local COL_BLOCK   = Color3.fromRGB(45,  100, 130)
local COL_EMPTY   = Color3.fromRGB(12,   28,  36)
local _mmBuilding = false

local function updateMinimap()
    if _mmBuilding then return end
    _mmBuilding = true
    
    task.spawn(function()
        local minX   = _G.MinX
        local maxX   = _G.MaxX
        local startY = _G.StartY
        local endY   = _G.EndY

        if not minX or not maxX or not startY or not endY then
            mmNoArea.Visible = true
            mmCoordLabel.Text = ""
            for _, t in ipairs(mmActiveTiles) do releaseTile(t) end
            mmActiveTiles = {}
            mmPlayer.Visible = false
            _mmBuilding = false
            return
        end
        mmNoArea.Visible = false

        local farmW = math.max(1, maxX - minX + 1)
        local farmH = math.max(1, endY - startY + 1)
        local PAD   = 6
        local mapW  = mmOuter.AbsoluteSize.X - PAD * 2
        local mapH  = 220 - PAD * 2 - 22
        if mapW <= 0 or mapH <= 0 then _mmBuilding = false; return end

        local cellSz = math.max(2, math.min(math.floor(mapW/farmW), math.floor(mapH/farmH)))
        local gap    = math.max(0, math.floor(cellSz * 0.1))
        local totalW = farmW * cellSz
        local totalH = farmH * cellSz
        local offX   = PAD + math.floor((mapW - totalW) / 2)
        local offY   = PAD + 20

        mmCanvas.Size     = UDim2.new(0, totalW, 0, totalH)
        mmCanvas.Position = UDim2.new(0, offX, 0, offY)

        for _, t in ipairs(mmActiveTiles) do releaseTile(t) end
        mmActiveTiles = {}

        local now = safeGetServerTime()
        local isMobile = (UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled)
        local CHUNK = isMobile and 4 or 8  -- Smaller chunks on mobile
        local tileCount = 0
        local maxTiles = isMobile and 200 or 400  -- Limit tiles on mobile

        for gx = 0, farmW - 1 do
            if not Gui or not Gui.Parent then break end
            
            local wx = minX + gx
            for gy = 0, farmH - 1 do
                tileCount = tileCount + 1
                if tileCount > maxTiles then break end  -- Stop if too many tiles
                
                local wy = startY + gy
                local tileId, tileData = WorldManager and WorldManager.GetTile(wx, wy, 1)
                local col
                
                if tileId and isSapling(tileId) then
                    local itemData = itemDataCache[tileId]
                    if itemData and tileData then
                        local elapsed  = now - (tileData.at or 0)
                        local growTime = getGrowTime(itemData.Rarity or 1)
                        col = (elapsed >= growTime) and COL_READY or COL_GROWING
                    else
                        col = COL_GROWING
                    end
                elseif tileId then
                    col = COL_BLOCK
                else
                    col = COL_EMPTY
                end
                
                local t = acquireTile()
                local sz = math.max(1, cellSz - gap * 2)
                t.Size             = UDim2.new(0, sz, 0, sz)
                t.Position         = UDim2.new(0, gx*cellSz+gap, 0, (farmH-1-gy)*cellSz+gap)
                t.BackgroundColor3 = col
                t.BackgroundTransparency = (col == COL_EMPTY) and 0.55 or 0
                table.insert(mmActiveTiles, t)
            end
            
            if tileCount > maxTiles then break end
            if gx % CHUNK == (CHUNK - 1) then task.wait() end
        end

        if movement and movement.Position then
            local wx = math.round(movement.Position.X / TILE_SIZE)
            local wy = math.round(movement.Position.Y / TILE_SIZE)
            local markerSz = math.max(4, cellSz + 2)
            mmPlayer.Size     = UDim2.new(0, markerSz, 0, markerSz)
            mmPlayer.Position = UDim2.new(
                0, offX + (wx-minX)*cellSz + math.floor((cellSz-markerSz)/2),
                0, offY + (farmH-1-(wy-startY))*cellSz + math.floor((cellSz-markerSz)/2)
            )
            mmPlayer.Visible = true
        else
            mmPlayer.Visible = false
        end

        mmCoordLabel.Text = "("..minX..","..startY..")→("..maxX..","..endY..")"
        mmFarmLabel.Text  = "FARM MAP  "..farmW.."×"..farmH
        _mmBuilding = false
    end)
end

local _scanRunning = false
local _scanReady   = {}
local _scanGrowing = {}

local function scanSaplings_async(onDone)
    if _scanRunning then 
        if onDone then onDone(_scanReady, _scanGrowing) end
        return 
    end
    _scanRunning = true
    
    task.spawn(function()
        local minX   = _G.MinX   or 0
        local maxX   = _G.MaxX   or 50
        local startY = _G.StartY or 0
        local endY   = _G.EndY   or 20
        local ready, growing = {}, {}
        local now = safeGetServerTime()
        
        local isMobile = (UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled)
        local ROW_CHUNK = isMobile and 5 or 10  -- Smaller chunks on mobile
        local maxSaplings = isMobile and 100 or 200  -- Limit results on mobile
        local tileCount = 0
        
        for x = minX, maxX do
            if not Gui or not Gui.Parent then break end
            if #ready + #growing >= maxSaplings then break end  -- Stop if we have enough
            
            for y = startY, endY do
                tileCount = tileCount + 1
                
                local tileId, tileData = WorldManager and WorldManager.GetTile(x, y, 1)
                if tileId and isSapling(tileId) and tileData then
                    local itemData = itemDataCache[tileId]
                    if itemData then
                        local plantTime = tileData.at or 0
                        local fruits    = tileData.n  or 0
                        local rarity    = itemData.Rarity or 1
                        local growTime  = getGrowTime(rarity)
                        local elapsed   = now - plantTime
                        local progress  = math.clamp(elapsed / growTime, 0, 1)
                        local info = {
                            x=x, y=y, 
                            name=itemData.Name, 
                            fruits=fruits,
                            progress=progress, 
                            timeLeft=math.max(0, growTime-elapsed)
                        }
                        
                        if progress >= 1 then 
                            table.insert(ready, info)
                        else 
                            table.insert(growing, info) 
                        end
                    end
                end
            end
            
            if (x - minX) % ROW_CHUNK == (ROW_CHUNK - 1) then 
                task.wait() 
            end
        end
        
        _scanReady   = ready
        _scanGrowing = growing
        _scanRunning = false
        
        if onDone then onDone(ready, growing) end
    end)
end
