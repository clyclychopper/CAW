                if mx > 0.1 then return 1 elseif mx < -0.1 then return -1 else return 0 end
            end
            local isMobileCheck = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
            if not isMobileCheck then
                local KEYS = {[Enum.KeyCode.A]=true,[Enum.KeyCode.D]=true,[Enum.KeyCode.Left]=true,[Enum.KeyCode.Right]=true}
                local lastDir2 = 0
                UserInputService.InputEnded:Connect(function(i) if KEYS[i.KeyCode] then movement.VelocityX=0 end end)
                UserInputService.InputBegan:Connect(function(i)
                    if KEYS[i.KeyCode] then
                        local d=getDir()
                        if d~=0 and d~=lastDir2 and lastDir2~=0 then movement.VelocityX=0 end
                        lastDir2=d
                    end
                end)
            end
            _G.FastWalkRunning2 = true
            local lastDir = 0
            local conn = RunService.Heartbeat:Connect(function()
                if not _G.FastWalkRunning2 then return end
                if serverRejecting then return end
                local dir = getDir()
                if dir == 0 then
                    local vx = movement.VelocityX
                    movement.VelocityX = math.abs(vx)>0.01 and vx*0.7 or 0
                    lastDir=0; return
                end
                if dir~=lastDir and lastDir~=0 then movement.VelocityX=0 end
                lastDir=dir; movement.VelocityX=dir*SPEED
            end)
            task.spawn(function()
                while _G.FastWalkRunning2 do task.wait(0.5) end
                conn:Disconnect(); movement.VelocityX=0
            end)
        end
    else
        _G.FastWalkRunning2 = false
        if movement then movement.VelocityX=0 end
    end
end)
