Hub.MAX_JUMP        = 3
Hub.MAX_FALL        = 20
Hub.getGrowTime = getGrowTime
Hub.isSapling   = isSapling

-- ─────────────────────────────────────────────────────────────
-- PTHT MODULE SCOPE
-- All pathfinding, movement, and farm automation lives here.
-- ─────────────────────────────────────────────────────────────
do
local TILE_SIZE       = Hub.TILE_SIZE       -- World units per tile (4.5)
local WORLD_W         = Hub.WORLD_W         -- Max X boundary
local WORLD_H         = Hub.WORLD_H         -- Max Y boundary
local ASTAR_MAX_NODES = Hub.ASTAR_MAX_NODES -- A* node expansion cap
local MAX_JUMP        = Hub.MAX_JUMP        -- Max jump height in tiles
local MAX_FALL        = Hub.MAX_FALL        -- Max fall distance in tiles

-- ── State flags ───────────────────────────────────────────────
local PTHT_Running = false  -- Main bot loop active?
local _dropLock    = false  -- Prevents re-entrant drop operations (ONE declaration only)

-- ── Tile collision cache ──────────────────────────────────────
-- Key: x*10000+y → true (blocked) / false (passable)
local tileCache        = {}
local tileCacheVersion = 0  -- Incremented on invalidation so path cache can detect staleness

-- ── Item data cache ───────────────────────────────────────────
-- Avoids repeated RequestItemData calls for the same item IDs
_G.itemDataCache = _G.itemDataCache or {}
local itemDataCache = _G.itemDataCache

-- ── Drop cooldown tracking ────────────────────────────────────
local _lastBlockDropTime   = 0
local _lastSaplingDropTime = 0
local DROP_ZONE_AVOID_DURATION = 4  -- seconds to avoid re-collecting own drops

-- ── Drop scan cache ───────────────────────────────────────────
local _lastDropScan       = 0
local _cachedDrops        = {}
local _cachedGems         = {}
local DROP_CACHE_INTERVAL = 0.5  -- Re-scan world drops every 0.5s max

-- ─────────────────────────────────────────────────────────────
-- TILE CACHE HELPERS
-- ─────────────────────────────────────────────────────────────

-- Marks all cached collision data as stale and bumps version
-- so any path cache entries referencing old tile data are discarded
local function invalidateTileCache()
    tileCache        = {}
    tileCacheVersion = tileCacheVersion + 1
end

-- Returns true if tile (x,y) is solid/blocked
local function isTileBlocked(x, y)
    return tileCache[x * 10000 + y] == true
end

-- Returns true if position is valid (not blocked, within bounds)
-- You CAN move through air, just not through solid blocks
local function isValidPosition(x, y)
    if x < 0 or x > WORLD_W or y < 0 or y > WORLD_H then return false end
    return not isTileBlocked(x, y)
end

-- Bakes the collision cache for the farm region + padding.
-- Called once at bot start and after any tile-invalidating event.
-- FIX: Added module nil-guard and retry on empty bake result.
local function prebakeCollision()
    if not WorldManager or not ItemsManager then
        warn("[YSHub] prebakeCollision: modules not ready, skipping")
        return false
    end

    invalidateTileCache()

    -- Farm area + 10-tile border for pathfinding headroom
    local x0 = math.max(0,       (_G.MinX   or 0)  - 10)
    local x1 = math.min(WORLD_W, (_G.MaxX   or 50) + 10)
    local y0 = math.max(0,       (_G.StartY or 0)  - 10)
    local y1 = math.min(WORLD_H, (_G.EndY   or 20) + 10)

    -- Pass 1: collect unique tile IDs we haven't cached item data for yet
    local uniqueIds = {}
    for x = x0, x1 do
        if not PTHT_Running then return false end
        for y = y0, y1 do
            local tileId = WorldManager.GetTile(x, y, 1) or WorldManager.GetTile(x, y, 2)
            if tileId and not isSapling(tileId) and not itemDataCache[tileId] then
                uniqueIds[tileId] = true
            end
        end
        -- Yield every 10 columns to avoid frame spikes
        if x % 10 == 0 then task.wait() end
    end

    -- Pass 2: bulk-request item data for all unseen tile IDs
    for tileId in pairs(uniqueIds) do
        if not PTHT_Running then return false end
        local ok, data = pcall(function() return ItemsManager.RequestItemData(tileId) end)
        if ok and data then itemDataCache[tileId] = data end
    end

        -- Pass 3: write collision booleans into tileCache
    -- IMPORTANT: Only check layer 1 (foreground) - layer 2 is background/decorative
    local tileCount = 0
    for x = x0, x1 do
        if not PTHT_Running then return false end
        for y = y0, y1 do
            local tileId = WorldManager.GetTile(x, y, 1)  -- Only layer 1 is solid
            if tileId then
                if isSapling(tileId) then
                    -- Saplings are passable — player walks through them
                    tileCache[x * 10000 + y] = false
                else
                    local data = itemDataCache[tileId]
                    -- Block if Collision >= 1; default to blocked if data missing
                    tileCache[x * 10000 + y] = (data == nil)
                        or (data.Tile and (data.Tile.Collision or 1) >= 1)
                end
            else
                tileCache[x * 10000 + y] = false  -- Empty tile = passable
            end
            tileCount = tileCount + 1
        end
        if x % 5 == 0 then task.wait() end
    end

    print(string.format("[YSHub] Collision bake complete: %d tiles", tileCount))
    return tileCount > 0
end

-- ─────────────────────────────────────────────────────────────
-- A* PATH CACHE
-- Stores recently computed paths keyed by start+goal.
-- Entries are invalidated when tileCacheVersion changes.
-- ─────────────────────────────────────────────────────────────
local _pathCache      = {}
local _pathCacheOrder = {}
local _pathCacheSize  = 0
local PATH_CACHE_MAX  = 200

local function _pathKey(sx, sy, gx, gy)
    return sx .. ":" .. sy .. ":" .. gx .. ":" .. gy
end

local function pathCacheGet(sx, sy, gx, gy)
    local entry = _pathCache[_pathKey(sx, sy, gx, gy)]
    if not entry then return nil end
    -- Discard stale entries when tiles have changed
    if entry.tileVersion ~= tileCacheVersion then
        _pathCache[_pathKey(sx, sy, gx, gy)] = nil
        _pathCacheSize = math.max(0, _pathCacheSize - 1)
        return nil
    end
    return entry.path
end

local function pathCachePut(sx, sy, gx, gy, path)
    local key = _pathKey(sx, sy, gx, gy)
    if _pathCache[key] then
        _pathCache[key] = { path = path, tileVersion = tileCacheVersion }
        return
    end
    -- Evict oldest entry when cache is full
    while _pathCacheSize >= PATH_CACHE_MAX do
        local oldKey = table.remove(_pathCacheOrder, 1)
        if oldKey and _pathCache[oldKey] then
            _pathCache[oldKey] = nil
            _pathCacheSize = _pathCacheSize - 1
        end
    end
    _pathCache[key] = { path = path, tileVersion = tileCacheVersion }
    table.insert(_pathCacheOrder, key)
    _pathCacheSize = _pathCacheSize + 1
end

local function pathCacheInvalidateAll()
    _pathCache      = {}
    _pathCacheOrder = {}
    _pathCacheSize  = 0
end

-- ─────────────────────────────────────────────────────────────
-- A* PRIORITY QUEUE (binary min-heap on .f score)
-- ─────────────────────────────────────────────────────────────
local _pqData = {}
local _pqSize = 0

local function pqPush(node)
    _pqSize = _pqSize + 1
    _pqData[_pqSize] = node
    -- Bubble up
    local i = _pqSize
    while i > 1 do
        local p = math.floor(i / 2)
        if _pqData[p].f <= _pqData[i].f then break end
        _pqData[p], _pqData[i] = _pqData[i], _pqData[p]
        i = p
    end
end

local function pqPop()
    if _pqSize == 0 then return nil end
    local top  = _pqData[1]
    local last = _pqData[_pqSize]
    _pqData[_pqSize] = nil
    _pqSize = _pqSize - 1
    if _pqSize > 0 then
        _pqData[1] = last
        -- Sift down
        local i = 1
        while true do
            local l, r, s = i * 2, i * 2 + 1, i
            if _pqData[l] and _pqData[l].f < _pqData[s].f then s = l end
            if _pqData[r] and _pqData[r].f < _pqData[s].f then s = r end
            if s == i then break end
            _pqData[i], _pqData[s] = _pqData[s], _pqData[i]
            i = s
        end
    end
    return top
end

local function pqReset()
    for i = 1, _pqSize do _pqData[i] = nil end
    _pqSize = 0
end

local function pqIsEmpty() return _pqSize == 0 end

-- ─────────────────────────────────────────────────────────────
-- A* PATHFINDER
-- Grid-based Manhattan-heuristic A*.
-- Returns a list of {x, y} tile waypoints from start → goal,
-- or nil if no path exists within ASTAR_MAX_NODES expansions.
-- ─────────────────────────────────────────────────────────────
-- ─────────────────────────────────────────────────────────────
-- GROWTOPIA-STYLE PATHFINDING
-- 
-- World model:
--   "solid" tile  = blocked, can be stood ON (y+1 above it)
--   "air" tile    = passable, player occupies this space
--   player stands at tile (x, y) meaning:
--     tileCache[x, y]   = AIR  (player body)
--     tileCache[x, y-1] = SOLID (ground beneath feet)
--
-- Valid moves from position (x, y):
--   WALK LEFT/RIGHT  : (x±1, y) is air AND (x±1, y-1) is solid
--   JUMP UP 1-3      : straight up or diagonal while ascending,
--                      must have clearance, must land on solid
--   FALL             : drop straight down or diagonally while
--                      no solid below current pos
-- ─────────────────────────────────────────────────────────────

local function isSolid(x, y)
    if x < 0 or x > WORLD_W or y < 0 or y > WORLD_H then return true end -- world boundary = solid
    return tileCache[x * 10000 + y] == true
end

local function isAir(x, y)
    if x < 0 or x > WORLD_W or y < 0 or y > WORLD_H then return false end
    return not isSolid(x, y)
end

-- Can the player stand at tile (x, y)?
-- Needs air at y and y+1 (head clearance), solid at y-1
local function canStandAt(x, y)
    return isAir(x, y)
       and isAir(x, y + 1)   -- head clearance
       and isSolid(x, y - 1) -- ground beneath feet
end

-- Build all valid moves from a standing position (x, y)
-- Returns list of {x, y, cost} reachable positions
local function getNeighbours(x, y)
    local result = {}

    -- ── WALK LEFT / RIGHT ──────────────────────────────────────
    for _, dx in ipairs({-1, 1}) do
        local nx = x + dx
        if canStandAt(nx, y) then
            table.insert(result, {x = nx, y = y, cost = 1})
        end
    end

    -- ── JUMP: up to 3 tiles high, land on solid ────────────────
    -- The player rises vertically then can move horizontally
    -- We model this as: for each jump height h (1–3),
    -- check all horizontal offsets reachable at that apex
    -- (simple model: can move ±h horizontal tiles at apex)
    for h = 1, 3 do
        -- Check vertical clearance for the jump column
        local clearUp = true
        for dy = 1, h do
            if not isAir(x, y + dy) or not isAir(x, y + dy + 1) then
                clearUp = false; break
            end
        end
        if not clearUp then break end -- can't jump higher if blocked

        -- At apex (x, y+h): try landing directly above or offset
        for dx = -h, h do
            local lx = x + dx
            local ly = y + h

            -- Check horizontal path at jump height is clear
            -- (simplified: just check destination, not every intermediate tile
            --  for longer jumps this is approximate but works well enough)
            local pathClear = true
            if dx ~= 0 then
                local stepX = dx > 0 and 1 or -1
                for cx = x + stepX, lx - stepX, stepX do
                    if not isAir(cx, ly) or not isAir(cx, ly + 1) then
                        pathClear = false; break
                    end
                end
            end

            if pathClear and canStandAt(lx, ly) then
                -- Cost = jump height + horizontal distance (penalise longer jumps)
                local jumpCost = h + math.abs(dx) * 0.5
                table.insert(result, {x = lx, y = ly, cost = jumpCost})
            end
        end
    end

    -- ── FALL: drop straight down or walk off edge ──────────────
    for _, dx in ipairs({-1, 0, 1}) do
        local fx = x + dx
        -- Can only step sideways if that tile is air (walk off ledge)
        if dx ~= 0 and not isAir(fx, y) then continue end

        -- Fall until we hit solid ground
        for drop = 1, 20 do -- max fall distance cap
            local fy = y - drop
            if fy < 0 then break end
            if isSolid(fx, fy - 1) and isAir(fx, fy) and isAir(fx, fy + 1) then
                -- Landed. Cost = fall distance (falling is free but prioritise shorter falls)
                table.insert(result, {x = fx, y = fy, cost = drop * 0.3 + math.abs(dx)})
                break
            elseif isSolid(fx, fy) then
                break -- hit a wall while falling
            end
        end
    end

    return result
end

-- ─────────────────────────────────────────────────────────────
-- A* using physics-aware neighbour function
-- ─────────────────────────────────────────────────────────────
local function astar(startX, startY, goalX, goalY)
      -- Check goal is not inside a solid block (can be in air for jumping)
  if isTileBlocked(goalX, goalY) then
      warn(string.format("[PTHT] Goal (%d,%d) is inside a solid block", goalX, goalY))
      return nil
  end
    if startX == goalX and startY == goalY then return {} end

    local closed   = {}
    local cameFrom = {}
    local gScore   = {}

    pqReset()

    local function tileKey(x, y) return x * 10000 + y end
    local function heuristic(x, y)
        -- Manhattan + vertical penalty (going up is expensive)
        local dy = goalY - y
        return math.abs(x - goalX) + math.abs(dy) + (dy > 0 and dy * 0.5 or 0)
    end

    local sk = tileKey(startX, startY)
    gScore[sk] = 0
    pqPush({x = startX, y = startY, g = 0, f = heuristic(startX, startY)})

    local expanded = 0

    while not pqIsEmpty() do
        expanded = expanded + 1
        if expanded > ASTAR_MAX_NODES then
            warn("[YSHub] A*: node limit hit"); return nil
        end

        local cur = pqPop()
        local ck  = tileKey(cur.x, cur.y)
        if closed[ck] then continue end
        closed[ck] = true

        if cur.x == goalX and cur.y == goalY then
            -- Reconstruct path
            local path = {}
            local node = ck
            while cameFrom[node] do
                local parent = cameFrom[node]
                table.insert(path, 1, {x = parent.x, y = parent.y})
                node = tileKey(parent.x, parent.y)
            end
            table.insert(path, {x = goalX, y = goalY})
            return path
        end

        for _, nb in ipairs(getNeighbours(cur.x, cur.y)) do
            local nk = tileKey(nb.x, nb.y)
            if closed[nk] then continue end
            local tg = cur.g + nb.cost
            if not gScore[nk] or tg < gScore[nk] then
                gScore[nk]   = tg
                cameFrom[nk] = cur
                pqPush({x = nb.x, y = nb.y, g = tg, f = tg + heuristic(nb.x, nb.y)})
            end
        end
    end

    return nil
end

-- ─────────────────────────────────────────────────────────────
-- LERP WALK
-- Key insight: X and Y movement are physically different in this
-- game. X is horizontal walking (VelocityX). Y is vertical/jump.
-- We move them in SEPARATE phases to avoid diagonal AC detection,
-- and handle Y specially since going "up" requires jump physics.
-- ─────────────────────────────────────────────────────────────
local WALK_SPT  = (UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled) and 0.22 or 0.16
local CLIMB_SPT = 0.20

local function smoothstep(t)
    t = math.clamp(t, 0, 1)
    return t * t * (3 - 2 * t)
end
local function lerp(a, b, t) return a + (b - a) * t end

-- Moves exactly ONE tile in ONE direction, snapping cleanly each step.
-- Never interpolates across multiple tiles at once.
local function stepOneTile(fromX, fromY, toX, toY)
    if not movement then return false end
    if not PTHT_Running or not _G.AutoPTHT then return false end

    local srcWorldX = fromX * TILE_SIZE
    local srcWorldY = fromY * TILE_SIZE
    local dstWorldX = toX   * TILE_SIZE
    local dstWorldY = toY   * TILE_SIZE

    -- Hard snap to source tile first — eliminates any prior drift
    movement.Position  = Vector3.new(srcWorldX, srcWorldY, 0)
    movement.VelocityX = 0
    movement.VelocityY = 0
    movement.Grounded  = true
    RunService.Heartbeat:Wait()  -- let server see clean origin

    local isVertical   = (toY ~= fromY)
    local duration     = isVertical and CLIMB_SPT or WALK_SPT
    local elapsed      = 0

    while elapsed < duration do
        if not PTHT_Running or not _G.AutoPTHT then
            movement.VelocityX = 0
            movement.VelocityY = 0
            return false
        end

        local dt = RunService.Heartbeat:Wait()
        elapsed  = math.min(elapsed + dt, duration)
        local t  = smoothstep(elapsed / duration)

        -- Interpolate position
        local wx = lerp(srcWorldX, dstWorldX, t)
        local wy = lerp(srcWorldY, dstWorldY, t)
        movement.Position = Vector3.new(wx, wy, 0)

        -- Set velocity to match direction
        if isVertical then
            local dir = toY > fromY and 1 or -1
            movement.Grounded  = false
            movement.VelocityY = dir * (TILE_SIZE / CLIMB_SPT)
            movement.VelocityX = 0
        else
            local dir = toX > fromX and 1 or -1
            movement.Grounded  = true
            movement.VelocityX = dir * (TILE_SIZE / WALK_SPT)
            movement.VelocityY = 0
        end
    end

    -- Hard snap to destination — no floating point residue
    movement.Position  = Vector3.new(dstWorldX, dstWorldY, 0)
    movement.VelocityX = 0
    movement.VelocityY = 0
    movement.Grounded  = true
    RunService.Heartbeat:Wait()  -- let server register arrival

    return true
end

local function walkToTile(targetX, targetY)
    if not movement then
        warn("[PTHT] walkToTile: movement is nil")
        return false
    end
    if not movement.Position then
        warn("[PTHT] walkToTile: movement.Position is nil")
        return false
    end
    if not PTHT_Running then return false end

-- In walkToTile, replace the startX/startY calculation with:
local startX = math.round(movement.Position.X / TILE_SIZE)
local startY = math.round(movement.Position.Y / TILE_SIZE)

  -- Check start is not inside a solid block
  if isTileBlocked(startX, startY) then
      warn("[PTHT] Start position is inside a block")
      return false
  end

    print("[PTHT] Walking ("..startX..","..startY..") -> ("..targetX..","..targetY..")")

    if startX == targetX and startY == targetY then return true end

    local path = pathCacheGet(startX, startY, targetX, targetY)

    if not path then
        print("🔍 [PTHT] Computing path...")
        path = astar(startX, startY, targetX, targetY)
        if not path then
            warn(string.format("[PTHT] No path (%d,%d)->(%d,%d), rebuilding cache",
                startX, startY, targetX, targetY))
            invalidateTileCache()
            pathCacheInvalidateAll()
            task.spawn(function() prebakeCollision() end)
            task.wait(0.5)
            path = astar(startX, startY, targetX, targetY)
            if not path then
                warn("[PTHT] ❌ Still no path after rebuild")
                return false
            end
        end
        print("✅ [PTHT] Path: "..#path.." waypoints")
        pathCachePut(startX, startY, targetX, targetY, path)
    end

    -- Walk tile by tile — re-read current tile position before each step
    -- so any server correction is absorbed cleanly
    local curX = startX
    local curY = startY

    for i, waypoint in ipairs(path) do
        if not PTHT_Running or not _G.AutoPTHT then
            movement.VelocityX = 0
            movement.VelocityY = 0
            return false
        end

        kickWatchdog()

        -- Re-snap current position from actual movement.Position
        -- This absorbs any server correction between steps
        curX = math.round(movement.Position.X / TILE_SIZE)
        curY = math.round(movement.Position.Y / TILE_SIZE)

        local nextX = waypoint.x
        local nextY = waypoint.y

        -- Skip if server already moved us there
        if curX == nextX and curY == nextY then continue end

        -- If server moved us off-path, replan from here
        if math.abs(curX - nextX) > 1 or math.abs(curY - nextY) > 1 then
            warn("[PTHT] Position drift detected at step "..i..", replanning")
            return walkToTile(targetX, targetY)
        end

        if not stepOneTile(curX, curY, nextX, nextY) then
            return false
        end
    end

    movement.VelocityX = 0
    movement.VelocityY = 0
    movement.Grounded  = true
    return true
end

-- ─────────────────────────────────────────────────────────────
-- WATCHDOG (moved before walkToTile so it can be called)
-- ─────────────────────────────────────────────────────────────
local _watchdogLastTick         = 0
local _watchdogExtended         = false
local WATCHDOG_TIMEOUT          = 15
local WATCHDOG_TIMEOUT_EXTENDED = 50
local _watchdogGeneration       = 0

local function kickWatchdog()
    _watchdogLastTick = os.clock()
end

local function setWatchdogExtended(state)
    _watchdogExtended = state
    kickWatchdog()
end

local function startWatchdog()
    _watchdogGeneration = _watchdogGeneration + 1
    local myGen = _watchdogGeneration

    task.spawn(function()
        task.wait(12)
        kickWatchdog()

        while PTHT_Running and _G.AutoPTHT and myGen == _watchdogGeneration do
            task.wait(5)
            if not PTHT_Running or not _G.AutoPTHT or myGen ~= _watchdogGeneration then break end

            local timeout = _watchdogExtended and WATCHDOG_TIMEOUT_EXTENDED or WATCHDOG_TIMEOUT
            local elapsed = os.clock() - _watchdogLastTick

            if elapsed > timeout then
                warn(string.format("[YSHub] Watchdog: frozen %.1fs - recovering", elapsed))

                _G.IsDropping = false
                _dropLock     = false
                _G.CancelInventoryOperation = false

                if movement then
                    local safeX = math.clamp(
                        (_G.MinX or 0) + math.floor(((_G.MaxX or 50) - (_G.MinX or 0)) / 2),
                        0, WORLD_W
                    )
                    local safeY = math.clamp(_G.StartY or 0, 0, WORLD_H)
                    movement.Position  = Vector3.new(safeX * TILE_SIZE, safeY * TILE_SIZE, 0)
                    movement.VelocityX = 0
                    movement.VelocityY = 0
                    movement.Grounded  = true
                    invalidateTileCache()
                    pathCacheInvalidateAll()
                    invalidateFarmCache()
                    showNotification("Bot frozen - auto-recovered", 4)
                else
                    warn("[YSHub] Watchdog: movement nil - stopping bot")
                    StopPTHT()
                end

                kickWatchdog()
            end
        end
    end)
end

local function walkToTile(targetX, targetY)
    if not movement then 
        warn("[PTHT] walkToTile: movement is nil")
        return false 
    end
    if not movement.Position then
        warn("[PTHT] walkToTile: movement.Position is nil")
        return false
    end
    if not PTHT_Running then return false end

        local startX = math.round(movement.Position.X / TILE_SIZE)
    local startY = math.round(movement.Position.Y / TILE_SIZE)

    print("[PTHT] Walking ("..startX..","..startY..") -> ("..targetX..","..targetY..")")

    if startX == targetX and startY == targetY then return true end

    local path = pathCacheGet(startX, startY, targetX, targetY)

    if not path then
        print("🔍 [PTHT] Computing path...")
        path = astar(startX, startY, targetX, targetY)
        if not path then
            warn(string.format("[PTHT] No path found (%d,%d)->(%d,%d), invalidating cache",
                startX, startY, targetX, targetY))
            invalidateTileCache()
            pathCacheInvalidateAll()
            task.spawn(function() prebakeCollision() end)
            task.wait(0.5)
            path = astar(startX, startY, targetX, targetY)
            if not path then
                warn("[PTHT] ❌ Still no path after cache rebuild")
                return false
            end
        end
        print("✅ [PTHT] Path found: "..#path.." waypoints")
        pathCachePut(startX, startY, targetX, targetY, path)
    else
        print("📦 [PTHT] Using cached path: "..#path.." waypoints")
    end

        local currentX = startX
    local currentY = startY
    
    for _, waypoint in ipairs(path) do
        if not PTHT_Running or _G.AutoPTHT == false then
            movement.VelocityX = 0
            return false
        end
        kickWatchdog()
        if not stepOneTile(currentX, currentY, waypoint.x, waypoint.y) then return false end
        currentX = waypoint.x
        currentY = waypoint.y
    end

        movement.VelocityX = 0
    movement.Grounded  = true
    return true
end

-- ─────────────────────────────────────────────────────────────
-- INVENTORY HELPERS
-- ─────────────────────────────────────────────────────────────
local _cachedUsedSlots       = 0
local _inventoryDirty        = true
local _lastInventoryCheck    = 0
local INVENTORY_RECHECK_INTERVAL = 3

local function markInventoryDirty() _inventoryDirty = true end

local function countUsedSlots()
    local now = os.clock()
    if not _inventoryDirty and (now - _lastInventoryCheck) < INVENTORY_RECHECK_INTERVAL then
        return _cachedUsedSlots
    end
    if not Inventory or not Inventory.MaxSlots then return 0 end
    local count = 0
    for slot = 1, Inventory.MaxSlots do
        if Inventory.Stacks[slot] and Inventory.Stacks[slot].Id then
            count = count + 1
        end
    end
    _cachedUsedSlots    = count
    _inventoryDirty     = false
    _lastInventoryCheck = now
    return count
end

local function countInInventory(itemID)
    if not Inventory or not Inventory.MaxSlots then return 0 end
    local count = 0
    for slot = 1, Inventory.MaxSlots do
        local stack = Inventory.Stacks[slot]
        if stack and stack.Id == itemID then
            count = count + (stack.Amount or 1)
        end
    end
    return count
end

-- Periodically mark inventory dirty so countUsedSlots refreshes
task.spawn(function()
    while Gui and Gui.Parent do
        task.wait(INVENTORY_RECHECK_INTERVAL)
        if PTHT_Running then _inventoryDirty = true end
    end
end)

-- ─────────────────────────────────────────────────────────────
-- ITEM DATA CACHE HELPER
-- ─────────────────────────────────────────────────────────────
local function getItemData(itemId)
    if not itemDataCache[itemId] then
        if ItemsManager then
            local ok, data = pcall(function() return ItemsManager.RequestItemData(itemId) end)
            if ok and data then itemDataCache[itemId] = data end
        end
    end
    return itemDataCache[itemId]
end

-- ─────────────────────────────────────────────────────────────
-- SAPLING HELPERS
-- ─────────────────────────────────────────────────────────────
local function getSaplingsFromInventory()
    local merged = {}
    if not Inventory or not Inventory.MaxSlots then return {} end

    for slot = 1, Inventory.MaxSlots do
        local stack = Inventory.Stacks[slot]
        if stack and stack.Id and stack.Id:sub(-8) == "_sapling" then
            local data = getItemData(stack.Id)
            if data then
                local id = stack.Id
                if not merged[id] then
                    merged[id] = { display = data.Name .. " Sapling", id = id, amount = 0 }
                end
                merged[id].amount = merged[id].amount + (stack.Amount or 1)
            end
        end
    end

    local result = {}
    for _, sap in pairs(merged) do table.insert(result, sap) end
    return result
end

-- ─────────────────────────────────────────────────────────────
-- SERVER TIME (with offset-anchored fallback)
-- ─────────────────────────────────────────────────────────────
local _serverTimeOffset = nil

local function safeGetServerTime()
    local ok, t = pcall(function() return workspace:GetServerTimeNow() end)
    if ok and t and t > 100000 then
        _serverTimeOffset = t - os.clock()
        return t
    end
    if _serverTimeOffset then return os.clock() + _serverTimeOffset end
    _serverTimeOffset = 0
    return os.clock()
end

-- ─────────────────────────────────────────────────────────────
-- FARM CACHE
-- Caches the result of scanning the farm area for ready/growing
-- saplings and empty spots. Invalidated on any world change.
-- ─────────────────────────────────────────────────────────────
local _farmCache        = { emptySpots = 0, readySaplings = {}, growingSaplings = 0 }
local _farmCacheVersion = 0
local _farmCacheBuilt   = 0
local SCAN_MIN_INTERVAL = 1
local _lastBreakCycleTime = 0
local BREAK_CYCLE_COOLDOWN = 3

local function invalidateFarmCache()
    _farmCacheVersion = _farmCacheVersion + 1
end

local function isFarmCacheValid()
    return _farmCacheBuilt == _farmCacheVersion
end

-- ─────────────────────────────────────────────────────────────
-- DROP / GEM COLLECTION
-- Scans nearby drops and gems then walks to each via walkToTile.
-- ─────────────────────────────────────────────────────────────
local function collectDropsAndGems(instant, centerPos, radius, skipOwnDropCheck)
    if _G.IsDropping then return 0 end
    if not movement  then return 0 end

    movement.Grounded  = true
    movement.VelocityY = 0

    -- Proximity filter helper
    local function isNearby(pos)
        if not centerPos or not radius then return true end
        return (Vector3.new(pos.X, pos.Y, 0) - centerPos).Magnitude <= radius
    end

    -- Avoids re-collecting our own freshly dropped items
    local function isOwnDrop(pos)
        if skipOwnDropCheck then return false end
        local now = os.clock()
        if _G.BlockDropX and _G.BlockDropY
        and (now - _lastBlockDropTime) < DROP_ZONE_AVOID_DURATION then
            if math.abs(pos.X - _G.BlockDropX   * TILE_SIZE) < TILE_SIZE * 6
            and math.abs(pos.Y - _G.BlockDropY  * TILE_SIZE) < TILE_SIZE * 6 then
                return true
            end
        end
        if _G.SaplingDropX and _G.SaplingDropY
        and (now - _lastSaplingDropTime) < DROP_ZONE_AVOID_DURATION then
            if math.abs(pos.X - _G.SaplingDropX * TILE_SIZE) < TILE_SIZE * 6
            and math.abs(pos.Y - _G.SaplingDropY * TILE_SIZE) < TILE_SIZE * 6 then
                return true
            end
        end
        return false
    end

    -- Use cached lists to avoid GetChildren() spam
    local now = os.clock()
    if now - _lastDropScan > DROP_CACHE_INTERVAL then
        _cachedDrops  = workspace.Drops:GetChildren()
        local gemsFolder = workspace:FindFirstChild("Gems")
        _cachedGems   = gemsFolder and gemsFolder:GetChildren() or {}
        _lastDropScan = now
    end

    -- Build sorted target list (Manhattan distance, cap at 50)
    local targets  = {}
    local curX     = movement.Position.X
    local curY     = movement.Position.Y

    for _, drop in ipairs(_cachedDrops) do
        if drop and drop.Parent and isNearby(drop.Position) and not isOwnDrop(drop.Position) then
            local dist = math.abs(drop.Position.X - curX) + math.abs(drop.Position.Y - curY)
            table.insert(targets, { pos = drop.Position, dist = dist })
        end
    end

    for _, gem in ipairs(_cachedGems) do
        if gem:IsA("BasePart") and gem:FindFirstChild("gems")
        and isNearby(gem.Position) and not isOwnDrop(gem.Position) then
            local dist = math.abs(gem.Position.X - curX) + math.abs(gem.Position.Y - curY)
            table.insert(targets, { pos = gem.Position, dist = dist })
        end
    end

    table.sort(targets, function(a, b) return a.dist < b.dist end)

    local collected = 0
    for i, target in ipairs(targets) do
        if not PTHT_Running or i > 50 then break end
        kickWatchdog()
        local tx = math.round(target.pos.X / TILE_SIZE)
        local ty = math.round(target.pos.Y / TILE_SIZE)
        walkToTile(tx, ty)
        task.wait(0.08)
        collected = collected + 1
    end

    movement.Grounded = true
    if collected > 0 then markInventoryDirty() end
    return collected
end

-- ─────────────────────────────────────────────────────────────
-- PLANTING / HARVESTING
-- ─────────────────────────────────────────────────────────────
local function plantSapling(x, y, saplingID)
    local remote = game.ReplicatedStorage.Remotes:FindFirstChild("PlayerPlaceItem")
    if not remote or not saplingID then return false end
    for slot = 1, Inventory.MaxSlots do
        local stack = Inventory.Stacks[slot]
        if stack and stack.Id == saplingID then
            remote:FireServer(Vector2.new(x, y), slot)
            markInventoryDirty()
            return true
        end
    end
    return false
end

local function placeBlock(x, y, blockID)
    local remote = game.ReplicatedStorage.Remotes:FindFirstChild("PlayerPlaceItem")
    if not remote or not blockID then return false end
    for slot = 1, Inventory.MaxSlots do
        local stack = Inventory.Stacks[slot]
        if stack and stack.Id == blockID then
            for attempt = 1, 3 do
                remote:FireServer(Vector2.new(x, y), slot)
                task.wait(0.2)
                local placed = WorldManager.GetTile(x, y, 1) or WorldManager.GetTile(x, y, 2)
                if placed then
                    tileCache[x * 10000 + y] = true
                    markInventoryDirty()
                    return true
                end
            end
            -- Final check after extended wait (server lag)
            task.wait(0.3)
            if WorldManager.GetTile(x, y, 1) or WorldManager.GetTile(x, y, 2) then
                tileCache[x * 10000 + y] = true
                markInventoryDirty()
                return true
            end
            return false
        end
    end
    return false
end

local function harvestSapling(x, y)
    local remote = game.ReplicatedStorage.Remotes:FindFirstChild("PlayerFist")
    if not remote then return false end

    local pos     = Vector2.new(x, y)
    local isMob   = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
    local delay   = isMob and 0.4 or 0.25
    local maxHits = isMob and 12 or 8

    for hit = 1, maxHits do
        if not PTHT_Running or not _G.AutoPTHT then return false end

        -- Check if it's already gone before wasting a hit
        if not (WorldManager.GetTile(x, y, 1) or WorldManager.GetTile(x, y, 2)) then
            tileCache[x * 10000 + y] = false
            markInventoryDirty()
            return true
        end

        kickWatchdog()
        RunService.Heartbeat:Wait()
        pcall(function() remote:FireServer(pos) end)
        task.wait(delay)
    end

    -- Final check
    task.wait(isMob and 0.5 or 0.3)
    if not (WorldManager.GetTile(x, y, 1) or WorldManager.GetTile(x, y, 2)) then
        tileCache[x * 10000 + y] = false
        markInventoryDirty()
        return true
    end

    -- Mark passable anyway so pathfinder doesn't route around ghost tiles
    tileCache[x * 10000 + y] = false
    return false
end

-- ─────────────────────────────────────────────────────────────
-- CONFIRM PROMPT HELPER
-- ─────────────────────────────────────────────────────────────
local function confirmPrompt(amount)
    local promptUI = LP.PlayerGui:FindFirstChild("UIPromptUI")
    if not promptUI then return false end
    local textBox    = promptUI:FindFirstChildWhichIsA("TextBox",    true)
    local confirmBtn = promptUI:FindFirstChildWhichIsA("TextButton", true)
    if not textBox or not confirmBtn then return false end

    textBox.Text = tostring(amount)
    task.wait(0.08)

    local fired = false
    if firesignal then
        pcall(function() firesignal(confirmBtn.MouseButton1Click); fired = true end)
    end
    if not fired and getconnections then
        pcall(function()
            for _, conn in ipairs(getconnections(confirmBtn.MouseButton1Click)) do
                conn:Fire(); fired = true
            end
        end)
    end
    if not fired then
        pcall(function() simulateclick(confirmBtn); fired = true end)
    end
    return fired
end

-- ─────────────────────────────────────────────────────────────
-- DROP ITEMS AT POSITION
-- Walks to drop coordinates, then fires the drop remote.
-- FIX: Single _dropLock at module scope (no shadowing).
-- FIX: pcall wrapper ensures lock always releases on error.
-- ─────────────────────────────────────────────────────────────
local function dropItemsAtPosition(itemID, dropX, dropY, customAmount, pressD)
    if not dropX or not dropY     then return false end
    if not movement or not Inventory then return false end

    -- Acquire exclusive lock with timeout
    local waited = 0
    while _dropLock do
        task.wait(0.1)
        waited = waited + 0.1
        if waited > 10 then
            warn("[YSHub] dropItemsAtPosition: stale lock, force-releasing")
            _dropLock     = false
            _G.IsDropping = false
            break
        end
    end
    _dropLock     = true
    _G.IsDropping = true

    -- Cleanup runs even if pcall catches an error
    local function cleanup()
        _G.IsDropping = false
        _dropLock     = false
        if dropX == _G.BlockDropX   and dropY == _G.BlockDropY   then _lastBlockDropTime   = os.clock() end
        if dropX == _G.SaplingDropX and dropY == _G.SaplingDropY then _lastSaplingDropTime = os.clock() end
        if movement then movement.Grounded = true; movement.VelocityY = 0 end
    end

    local ok, err = pcall(function()
        -- Walk to drop tile
        if not walkToTile(dropX, dropY) then return end

        -- Confirm arrival
        local ax = math.round(movement.Position.X / TILE_SIZE)
        local ay = math.round(movement.Position.Y / TILE_SIZE)
        if ax ~= dropX or ay ~= dropY then
            walkToTile(dropX, dropY)
        end

        movement.Grounded  = true
        movement.VelocityY = 0
        task.wait(0.5)

        local remote = game.ReplicatedStorage.Remotes:FindFirstChild("PlayerDrop")
        if not remote then return end

        local totalInv   = countInInventory(itemID)
        local targetDrop = customAmount or math.floor(totalInv / 2)
        local dropped    = 0
        local MAX_BATCH  = 200
        local MAX_LOOPS  = 20

        if pressD == nil then pressD = true end

        -- Optional D-key press for drop UI
        if pressD and _vimReliable then
            pcall(function() VIM:SendKeyEvent(true,  Enum.KeyCode.D, false, game) end)
            task.wait(0.1)
            pcall(function() VIM:SendKeyEvent(false, Enum.KeyCode.D, false, game) end)
            task.wait(0.2)
        end

        local loops = 0
        while dropped < targetDrop and loops < MAX_LOOPS do
            if _G.CancelInventoryOperation then break end
            if not PTHT_Running and not _G.InventoryOperationActive then break end

            loops = loops + 1
            local batch = math.min(MAX_BATCH, targetDrop - dropped)

            -- Find item slot
            local dropSlot = nil
            for slot = 1, Inventory.MaxSlots do
                local stack = Inventory.Stacks[slot]
                if stack and stack.Id == itemID then dropSlot = slot; break end
            end
            if not dropSlot then break end  -- Item gone from inventory

            -- Fire drop remote (with one retry)
            local fireOk = pcall(function() remote:FireServer(dropSlot) end)
            if not fireOk then
                task.wait(0.3)
                pcall(function() remote:FireServer(dropSlot) end)
            end
            task.wait(0.4)

            -- Confirm the amount prompt
            local confirmed = false
            for attempt = 1, 5 do
                if confirmPrompt(batch) then confirmed = true; break end
                task.wait(0.3 + attempt * 0.05)
            end

            if confirmed then
                dropped = dropped + batch
                markInventoryDirty()
                task.wait(0.5)
            else
                warn("[YSHub] dropItemsAtPosition: confirmPrompt failed, aborting")
                break
            end
        end
    end)

    cleanup()

    if not ok then
        warn("[YSHub] dropItemsAtPosition error: " .. tostring(err))
    end
    return true
end

-- ─────────────────────────────────────────────────────────────
-- TRASH ITEMS
-- ─────────────────────────────────────────────────────────────
local function trashItemsFromInventory(itemID, customAmount)
    if not Inventory then return false end
    local remote = game.ReplicatedStorage.Remotes:FindFirstChild("PlayerItemTrash")
    if not remote then return false end

    local target  = customAmount or countInInventory(itemID)
    local trashed = 0
    local MAX_BATCH = 200
    local MAX_LOOPS = 20
    local loops   = 0

    while trashed < target and loops < MAX_LOOPS do
        if _G.CancelInventoryOperation then break end
        loops = loops + 1

        local batch = math.min(MAX_BATCH, target - trashed)
        local slot  = nil
        for s = 1, Inventory.MaxSlots do
            if Inventory.Stacks[s] and Inventory.Stacks[s].Id == itemID then
                slot = s; break
            end
        end
        if not slot then break end

        remote:FireServer(slot)
        task.wait(0.3)

        local confirmed = false
        for attempt = 1, 5 do
            if confirmPrompt(batch) then confirmed = true; break end
            task.wait(0.3 + attempt * 0.05)
        end

        if confirmed then
            trashed = trashed + batch
            markInventoryDirty()
            task.wait(0.4)
        else
            break
        end
    end
    return true
end

-- ─────────────────────────────────────────────────────────────
-- DO PLANT — fills empty farm tiles with saplings
-- ─────────────────────────────────────────────────────────────
local function doPlant(ctx)
    if not WorldManager or not Inventory then return end

    -- Collect all empty tile positions in the farm area
    local emptyList = {}
    for x = ctx.minX, ctx.maxX do
        for y = ctx.startY, ctx.endY, 2 do
            if not WorldManager.GetTile(x, y, 1) then
                table.insert(emptyList, { x = x, y = y })
            end
        end
    end

    -- Boustrophedon sort (snake pattern) — minimises travel distance
    table.sort(emptyList, function(a, b)
        if a.y ~= b.y then return a.y < b.y end
        local row = math.floor((a.y - ctx.startY) / 2)
        return (row % 2 == 0) and (a.x < b.x) or (a.x > b.x)
    end)

    for _, spot in ipairs(emptyList) do
        if not PTHT_Running or not _G.AutoPTHT then return end
        if countInInventory(ctx.saplingID) == 0 then break end
        kickWatchdog()

        if not WorldManager.GetTile(spot.x, spot.y, 1) then
            if walkToTile(spot.x, spot.y) then
                plantSapling(spot.x, spot.y, ctx.saplingID)
                task.wait(ctx.plantSpeed)
                -- Retry once if placement didn't register
                if not WorldManager.GetTile(spot.x, spot.y, 1) then
                    plantSapling(spot.x, spot.y, ctx.saplingID)
                    task.wait(0.1)
                end
            end
        end
    end

    invalidateFarmCache()
end

-- ─────────────────────────────────────────────────────────────
-- RECOVER FROM — visit a drop zone and collect items there
-- ─────────────────────────────────────────────────────────────
local function recoverFrom(dropX, dropY)
    if not walkToTile(dropX, dropY) then return 0 end
    task.wait(0.3)

    local pattern = { {0,0}, {1,0}, {-1,0}, {0,1}, {0,-1} }
    local total   = 0

    for _, offset in ipairs(pattern) do
        if not PTHT_Running then break end
        local tx, ty = dropX + offset[1], dropY + offset[2]

        if tx >= 0 and tx <= WORLD_W and ty >= 0 and ty <= WORLD_H
        and not isTileBlocked(tx, ty) then
            walkToTile(tx, ty)
            task.wait(0.3)
            local collected = collectDropsAndGems(
                false,
                Vector3.new(tx * TILE_SIZE, ty * TILE_SIZE, 0),
                TILE_SIZE * 2,
                true
            )
            total = total + collected
            if collected > 0 then task.wait(0.2) end
        end
    end

    task.wait(total > 0 and 1.0 or 0.5)
    return total
end

-- ─────────────────────────────────────────────────────────────
-- DO BREAK CYCLE — place blocks above farm, break them, collect
-- ─────────────────────────────────────────────────────────────
local function doBreakCycle(ctx)
    local nowEntry = safeGetServerTime()
    if (nowEntry - _lastBreakCycleTime) < BREAK_CYCLE_COOLDOWN then return end

    if not WorldManager or not movement then return end

    local midX = math.floor((ctx.minX + ctx.maxX) / 2)

    if not walkToTile(midX, ctx.endY + 1) then
        _lastBreakCycleTime = safeGetServerTime()
        return
    end

    setWatchdogExtended(true)

    -- Place two rows of blocks above the farm
    for xOff = -2, 2 do
        if not PTHT_Running or not _G.AutoPTHT then return end
        for _, py in ipairs({ ctx.endY + 1, ctx.endY + 2 }) do
            local px = midX + xOff
            if not (WorldManager.GetTile(px, py, 1) or WorldManager.GetTile(px, py, 2))
            and countInInventory(ctx.blockID) > 0 then
                placeBlock(px, py, ctx.blockID)
                task.wait(0.05)
            end
        end
    end

        -- Build list of tiles to break
    local tilesToBreak = {}
    for xOff = -2, 2 do
        local px1, py1 = midX + xOff, ctx.endY + 1
        local px2, py2 = midX + xOff, ctx.endY + 2
        if WorldManager.GetTile(px1, py1, 1) or WorldManager.GetTile(px1, py1, 2) then
            table.insert(tilesToBreak, { x = px1, y = py1 })
        end
        if WorldManager.GetTile(px2, py2, 1) or WorldManager.GetTile(px2, py2, 2) then
            table.insert(tilesToBreak, { x = px2, y = py2 })
        end
    end

    -- Mark break zone tiles as passable so pathfinder can reach them
    for _, tile in ipairs(tilesToBreak) do
        tileCache[tile.x * 10000 + tile.y] = false
    end

    if #tilesToBreak == 0 then
        _lastBreakCycleTime = safeGetServerTime()
        setWatchdogExtended(false)
        return
    end

    -- Break all tiles with attempt cap
    local broken      = {}
    local attempts    = {}
    local MAX_ATTEMPTS = 8
    for _, t in ipairs(tilesToBreak) do
        attempts[t.x * 10000 + t.y] = 0
    end

    local allDone     = false
    local cycleStart  = safeGetServerTime()
    local iter        = 0

    while PTHT_Running and _G.AutoPTHT and not allDone do
        iter = iter + 1
        if iter % 5 == 0 and (safeGetServerTime() - cycleStart) > 30 then
            warn("[YSHub] Break cycle timeout"); break
        end
        kickWatchdog()
        allDone = true

        for _, tile in ipairs(tilesToBreak) do
            if not PTHT_Running or not _G.AutoPTHT then break end
            local k = tile.x * 10000 + tile.y
            if broken[k] then continue end

            local stillThere = WorldManager.GetTile(tile.x, tile.y, 1)
                            or WorldManager.GetTile(tile.x, tile.y, 2)

            if not stillThere then
                broken[k] = true
                tileCache[k] = false
                continue
            end

            if attempts[k] >= MAX_ATTEMPTS then
                broken[k] = true
                warn("[YSHub] Tile ("..tile.x..","..tile.y..") max attempts, skipping")
                continue
            end

            allDone = false
            attempts[k] = attempts[k] + 1
            harvestSapling(tile.x, tile.y)

            local isMob = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
            task.wait(isMob and 0.3 or math.max(0.05, ctx.breakSpeed))
        end
    end

    _lastBreakCycleTime = safeGetServerTime()
    
    -- Rebuild tile cache after breaking to reflect new state
    invalidateTileCache()
    invalidateFarmCache()

    -- Collect drops near break site
    local bCount = 0
    for _ in pairs(broken) do bCount = bCount + 1 end
    task.wait(0.3 + bCount * 0.05)

    local cx = midX * TILE_SIZE
    local cy = (ctx.endY + 1.5) * TILE_SIZE
    collectDropsAndGems(false, Vector3.new(cx, cy, 0), TILE_SIZE * 8)

    setWatchdogExtended(false)
    task.wait(0.15)
end

-- ─────────────────────────────────────────────────────────────
-- STOP BOT
-- ─────────────────────────────────────────────────────────────
local function StopPTHT()
    PTHT_Running  = false
    _G.AutoPTHT   = false
    _G.IsDropping = false

    -- Close any open UI prompts
    local managers = game.ReplicatedStorage:FindFirstChild("Managers")
    if managers then
        local uiManager = managers:FindFirstChild("UIManager")
        if uiManager then
            local ev = uiManager:FindFirstChild("UIPromptEvent")
            if ev then pcall(function() ev:FireServer({ ButtonAction = "cls" }) end) end
        end
    end

    task.wait(0.2)
    if movement then
        movement.Grounded  = true
        movement.VelocityX = 0
        movement.VelocityY = 0
    end
end

-- ─────────────────────────────────────────────────────────────
-- START BOT — main farming loop
-- ─────────────────────────────────────────────────────────────
local function StartPTHT()
    if PTHT_Running then return end

                print("\n🚀 [PTHT] Starting bot...")
    print("📦 [PTHT] Checking modules...")
    print("   WorldManager: ", WorldManager and "✓" or "✗")
    print("   ItemsManager: ", ItemsManager and "✓" or "✗")
    print("   Inventory: ", Inventory and "✓" or "✗")
    print("   movement: ", movement and "✓" or "✗")

    if not WorldManager or not ItemsManager or not Inventory or not movement then
        showNotification("⚠️ Modules not loaded yet. Wait and retry.", 5)
        warn("[PTHT] ❌ Missing modules, cannot start")
        return
    end

    print("📍 [PTHT] Farm area: ("..tostring(_G.MinX or 0)..","..tostring(_G.StartY or 0)..") -> ("..tostring(_G.MaxX or 50)..","..tostring(_G.EndY or 20)..")")
    print("🌱 [PTHT] Sapling: "..tostring(_G.SelectedSaplingName or "none"))
    print("🧱 [PTHT] Block: "..tostring(_G.SelectedBlockName or "none"))

    PTHT_Running = true
    invalidateFarmCache()

    task.spawn(function()
                        -- Bake collision on start; retry up to 3 times if it comes back empty
        print("🔧 [PTHT] Building collision cache...")
        local bakeOk = false
        for attempt = 1, 3 do
            bakeOk = prebakeCollision()
            if bakeOk then 
                print("✅ [PTHT] Collision cache built successfully")
                break 
            end
            warn("[YSHub] Bake attempt "..attempt.." returned empty, retrying in 1s")
            task.wait(1)
        end
        if not bakeOk then
            warn("[YSHub] ❌ Collision bake failed after 3 attempts — bot may path through walls")
        end

        kickWatchdog()
        startWatchdog()

        local _lastScanTime = 0

        while PTHT_Running and _G.AutoPTHT do
            kickWatchdog()

            local saplingID = _G.SelectedSaplingID
            local blockID   = _G.SelectedBlockID
            if not saplingID or not blockID then
                warn("[YSHub] No sapling/block selected — stopping")
                StopPTHT(); return
            end

            local minX   = _G.MinX   or 0
            local maxX   = _G.MaxX   or 50
            local startY = _G.StartY or 0
            local endY   = _G.EndY   or 20

            -- Speed settings (slider 1–100, higher = faster)
            local plantSpeed   = (101 - (_G.PlantSpeed   or 50)) / 100
            local harvestSpeed = (101 - (_G.HarvestSpeed or 50)) / 100
            local breakSpeed   = (101 - (_G.BreakSpeed   or 50)) / 200

            local ctx = {
                minX = minX, maxX = maxX, startY = startY, endY = endY,
                saplingID = saplingID, blockID = blockID,
                plantSpeed = plantSpeed, harvestSpeed = harvestSpeed, breakSpeed = breakSpeed,
            }

            local seeds        = countInInventory(saplingID)
            local blocks       = countInInventory(blockID)
            local farmWidth    = maxX - minX + 1
            local farmRows     = math.floor((endY - startY) / 2) + 1
            local totalCapacity = farmWidth * farmRows

            -- Re-scan farm state if cache is stale
            local now = safeGetServerTime()
            if not isFarmCacheValid() or (now - _lastScanTime) >= SCAN_MIN_INTERVAL then
                local scanVersion   = _farmCacheVersion
                local emptySpots    = 0
                local readySaplings = {}
                local growingSap    = 0
                local tileCount     = 0

                for x = minX, maxX do
                    for y = startY, endY, 2 do
                        local tileId, tileData = WorldManager.GetTile(x, y, 1)
                        if not tileId then
                            emptySpots = emptySpots + 1
                        elseif isSapling(tileId) and tileData then
                            local itemData = getItemData(tileId)
                            if itemData then
                                local elapsed  = safeGetServerTime() - (tileData.at or 0)
                                local growTime = getGrowTime(itemData.Rarity or 1)
                                if elapsed >= growTime then
                                    table.insert(readySaplings, { x = x, y = y })
                                else
                                    growingSap = growingSap + 1
                                end
                            end
                        end
                        tileCount = tileCount + 1
                        if tileCount % 8 == 0 then task.wait() end
                    end
                end

                -- Only commit scan if cache wasn't invalidated under us
                if scanVersion == _farmCacheVersion then
                    _farmCache      = { emptySpots = emptySpots, readySaplings = readySaplings, growingSaplings = growingSap }
                    _farmCacheBuilt = _farmCacheVersion
                    _lastScanTime   = safeGetServerTime()
                else
                    task.wait(0.1); continue
                end
            end

            local emptySpots      = _farmCache.emptySpots
            local readySaplings   = _farmCache.readySaplings
            local growingSaplings = _farmCache.growingSaplings

            -- Auto-drop blocks when inventory full
            if _G.AutoDropBlocks and countUsedSlots() >= Inventory.MaxSlots - 2
            and _G.BlockDropX and _G.BlockDropY then
                dropItemsAtPosition(blockID, _G.BlockDropX, _G.BlockDropY, math.floor(blocks / 2), false)
                task.wait(1)
                blocks = countInInventory(blockID)
            end

            -- Auto-drop excess saplings
            if _G.AutoDropSaplings and seeds > totalCapacity + 200
            and _G.SaplingDropX and _G.SaplingDropY then
                dropItemsAtPosition(saplingID, _G.SaplingDropX, _G.SaplingDropY, seeds - totalCapacity, false)
                task.wait(1)
                seeds = countInInventory(saplingID)
            end

            -- ── Priority: Harvest ready saplings ──────────────
            if #readySaplings > 0 then
                table.sort(readySaplings, function(a, b)
                    return a.y == b.y and a.x < b.x or a.y < b.y
                end)

                for _, sapling in ipairs(readySaplings) do
                    if not PTHT_Running or not _G.AutoPTHT then return end
                    kickWatchdog()

                    if not walkToTile(sapling.x, sapling.y) then
                        warn("[YSHub] Walk failed to ("..sapling.x..","..sapling.y.."), skipping")
                        continue
                    end

                    -- Mid-harvest drop if inventory full
                    if countUsedSlots() >= Inventory.MaxSlots - 3
                    and _G.BlockDropX and _G.BlockDropY then
                        blocks = countInInventory(blockID)
                        if blocks > 0 then
                            dropItemsAtPosition(blockID, _G.BlockDropX, _G.BlockDropY, math.floor(blocks / 2), false)
                            task.wait(0.5)
                            walkToTile(sapling.x, sapling.y)
                        end
                    end

                    local tileId = WorldManager.GetTile(sapling.x, sapling.y, 1)
                    if tileId and isSapling(tileId) then
                        harvestSapling(sapling.x, sapling.y)
                        task.wait(harvestSpeed)
                        task.wait(0.15)
                    end
                end

                -- Collect drops in farm area after harvest pass
                local cx = ((minX + maxX) / 2) * TILE_SIZE
                local cy = ((startY + endY) / 2) * TILE_SIZE
                local cr = math.max((maxX-minX+1), (endY-startY+1)) * TILE_SIZE / 2 + TILE_SIZE * 3
                collectDropsAndGems(false, Vector3.new(cx, cy, 0), cr)

                seeds = countInInventory(saplingID)
                invalidateFarmCache()

            -- ── Plant if there are empty spots and enough seeds ──
            elseif emptySpots > 0 and seeds >= totalCapacity then
                doPlant(ctx)

            -- ── Break cycle if we have blocks but empty spots ────
            elseif emptySpots > 0 and blocks > 0 then
                local cooldownLeft = BREAK_CYCLE_COOLDOWN - (safeGetServerTime() - _lastBreakCycleTime)
                if cooldownLeft <= 0 then
                    doBreakCycle(ctx)
                    task.wait(0.3)
                    if PTHT_Running and _G.AutoPTHT
                    and countInInventory(saplingID) >= totalCapacity then
                        doPlant(ctx)
                    end
                else
                    task.wait(math.min(cooldownLeft, 0.2) + 0.05)
                end

            -- ── All growing, wait ────────────────────────────────
            elseif emptySpots == 0 and growingSaplings > 0 then
                task.wait(3)
                invalidateFarmCache()

            -- ── Nothing to do, try to recover from drop zones ────
            else
                local recoveredBlocks = 0
                if _G.BlockDropX and _G.BlockDropY then
                    recoveredBlocks = recoverFrom(_G.BlockDropX, _G.BlockDropY)
                    if recoveredBlocks > 0 then blocks = countInInventory(blockID) end
                end
                if blocks == 0 and _G.SaplingDropX and _G.SaplingDropY then
                    local recoveredSeeds = recoverFrom(_G.SaplingDropX, _G.SaplingDropY)
                    if recoveredSeeds > 0 then seeds = countInInventory(saplingID) end
                end
                if blocks == 0 and seeds == 0 then
                    task.wait(recoveredBlocks == 0 and 5 or 1)
                end
            end

            RunService.Heartbeat:Wait()
        end

        PTHT_Running = false
    end)
end

