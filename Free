local Inventory, ItemsManager, WorldManager, movement
local VIM = game:GetService("VirtualInputManager")

local function safeRequire(path)
    local ok, result = pcall(function() return require(path) end)
    if ok then return result end
    return nil
end

local function tryInstantLoad()
    local mf  = game.ReplicatedStorage:FindFirstChild("Modules")
    local mgf = game.ReplicatedStorage:FindFirstChild("Managers")
    local ps  = LP:FindFirstChild("PlayerScripts")
    if mf then
        local m = mf:FindFirstChild("Inventory")
        if m then Inventory = safeRequire(m) end
    end
    if mgf then
        local m = mgf:FindFirstChild("ItemsManager")
        if m then ItemsManager = safeRequire(m) end
        local w = mgf:FindFirstChild("WorldManager")
        if w then WorldManager = safeRequire(w) end
    end
    if ps then
        local mv = ps:FindFirstChild("PlayerMovement")
        if mv then movement = safeRequire(mv) end
    end
end
tryInstantLoad()

local function loadModulesWithRetry()
    local maxRetries = 15
    local retryDelay = 0.5
    task.wait(2)
    for attempt = 1, maxRetries do
        local modulesFolder  = game.ReplicatedStorage:FindFirstChild("Modules")
        local managersFolder = game.ReplicatedStorage:FindFirstChild("Managers")
        local playerScripts  = LP:FindFirstChild("PlayerScripts")
        if modulesFolder and not Inventory then
            local m = modulesFolder:FindFirstChild("Inventory")
            if m then Inventory = safeRequire(m) end
        end
        if managersFolder then
            if not ItemsManager then
                local m = managersFolder:FindFirstChild("ItemsManager")
                if m then ItemsManager = safeRequire(m) end
            end
            if not WorldManager then
                local m = managersFolder:FindFirstChild("WorldManager")
                if m then WorldManager = safeRequire(m) end
            end
        end
        if playerScripts and not movement then
            local mv = playerScripts:FindFirstChild("PlayerMovement")
            if mv then movement = safeRequire(mv) end
        end
        if Inventory and ItemsManager and WorldManager and movement then
            showNotification("✅ All modules loaded!", 3)
            break
        end
        if attempt == maxRetries then
            local missing = {}
            if not Inventory    then table.insert(missing, "Inventory") end
            if not ItemsManager then table.insert(missing, "ItemsManager") end
            if not WorldManager then table.insert(missing, "WorldManager") end
            if not movement     then table.insert(missing, "Movement") end
            showNotification("⚠️ Missing: "..table.concat(missing, ", "), 8)
        end
        task.wait(retryDelay)
    end
end
task.spawn(loadModulesWithRetry)

