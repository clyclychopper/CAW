local function mkSlider(parent, text, minV, maxV, defV, unit, order, cb)
    local wrap = Instance.new("Frame")
    wrap.Size             = UDim2.new(1, 0, 0, 50)
    wrap.BackgroundTransparency = 1
    wrap.LayoutOrder      = order or 99
    wrap.ZIndex           = 5
    wrap.Parent           = parent
    local top = Instance.new("Frame")
    top.Size             = UDim2.new(1, 0, 0, 18)
    top.BackgroundTransparency = 1
    top.ZIndex           = 6
    top.Parent           = wrap
    local lbl = Instance.new("TextLabel")
    lbl.Size             = UDim2.new(0.65, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text             = text
    lbl.TextColor3       = T.textMain
    lbl.TextSize         = 14
    lbl.Font             = Enum.Font.GothamBold
    lbl.TextXAlignment   = Enum.TextXAlignment.Left
    lbl.ZIndex           = 6
    lbl.Parent           = top
    local valLbl = Instance.new("TextLabel")
    valLbl.Size          = UDim2.new(0.35, 0, 1, 0)
    valLbl.Position      = UDim2.new(0.65, 0, 0, 0)
    valLbl.BackgroundTransparency = 1
    valLbl.Text          = defV .. (unit or "")
    valLbl.TextColor3    = T.accent
    valLbl.TextSize      = 13
    valLbl.Font          = Enum.Font.GothamBold
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.ZIndex        = 6
    valLbl.Parent        = top
    local track = Instance.new("Frame")
    track.Size           = UDim2.new(1, 0, 0, 5)
    track.Position       = UDim2.new(0, 0, 0, 32)
    track.BackgroundColor3 = T.cardInner
    track.BorderSizePixel = 0
    track.ZIndex         = 6
    track.Parent         = wrap
    corner(track, 3)
    stroke(track, T.border, 1)
    local pct = (defV - minV) / (maxV - minV)
    local fill = Instance.new("Frame")
    fill.Size            = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = T.purple2
    fill.BorderSizePixel = 0
    fill.ZIndex          = 7
    fill.Parent          = track
    corner(fill, 3)
    local fillGrad = Instance.new("UIGradient")
    fillGrad.Color    = ColorSequence.new(T.purple1, T.accentGlow)
    fillGrad.Rotation = 0
    fillGrad.Parent   = fill
    local knob = Instance.new("Frame")
    knob.Size            = UDim2.new(0, 14, 0, 14)
    knob.Position        = UDim2.new(pct, -7, 0.5, -7)
    knob.BackgroundColor3 = T.white
    knob.ZIndex          = 8
    knob.BorderSizePixel = 0
    knob.Parent          = track
    corner(knob, 7)
    local knobStroke = stroke(knob, T.accent, 1.5)
    local knobGlowFrame = Instance.new("Frame")
    knobGlowFrame.Size           = UDim2.new(0, 20, 0, 20)
    knobGlowFrame.Position       = UDim2.new(pct, -10, 0.5, -10)
    knobGlowFrame.BackgroundColor3 = T.purple2
    knobGlowFrame.BackgroundTransparency = 0.65
    knobGlowFrame.BorderSizePixel = 0
    knobGlowFrame.ZIndex         = 6
    knobGlowFrame.Parent         = track
    corner(knobGlowFrame, 10)
    local dragging = false
    local hit = Instance.new("ImageButton")
    hit.Size             = UDim2.new(1, 0, 0, 28)
    hit.Position         = UDim2.new(0, 0, 0.5, -14)
    hit.BackgroundTransparency = 1
    hit.Image            = ""
    hit.ZIndex           = 9
    hit.Parent           = track
    local function upd(pos)
        local rel = math.clamp((pos.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor(minV + rel*(maxV-minV) + 0.5)
        valLbl.Text = val .. (unit or "")
        tween(fill,         {Size     = UDim2.new(rel, 0, 1, 0)}, 0.05)
        tween(knob,         {Position = UDim2.new(rel, -7, 0.5, -7)}, 0.05)
        tween(knobGlowFrame,{Position = UDim2.new(rel,-10, 0.5,-10)}, 0.05)
        if cb then cb(val) end
    end
    hit.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; upd(i.Position)
            tween(knobGlowFrame, {BackgroundTransparency = 0.4},  0.1)
            tween(knobStroke,    {Thickness = 2.5},                0.1)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then upd(i.Position) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            tween(knobGlowFrame, {BackgroundTransparency = 0.65}, 0.1)
            tween(knobStroke,    {Thickness = 1.5},                0.1)
        end
    end)
    local api = {}
    function api.setValue(val)
        val = math.clamp(val, minV, maxV)
        local rel = (val - minV) / (maxV - minV)
        valLbl.Text            = val .. (unit or "")
        fill.Size              = UDim2.new(rel, 0, 1, 0)
        knob.Position          = UDim2.new(rel, -7, 0.5, -7)
        knobGlowFrame.Position = UDim2.new(rel,-10, 0.5,-10)
        if cb then cb(val) end
    end
    return wrap, api
end

