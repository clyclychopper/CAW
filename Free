                                   or ColorSequence.new(T.cardInner, T.cardInner)
    bgGradInst.Rotation = 0
    bgGradInst.Parent   = bg
    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, 16, 0, 16)
    knob.Position         = default and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
    knob.BackgroundColor3 = T.white
    knob.BorderSizePixel  = 0
    knob.ZIndex           = 7
    knob.Parent           = bg
    corner(knob, 8)
    local knobGlow = Instance.new("UIStroke")
    knobGlow.Color     = default and T.accentGlow or T.textDim
    knobGlow.Thickness = 1
    knobGlow.Parent    = knob
    local state = default or false
    local hit = Instance.new("ImageButton")
    hit.Size               = UDim2.new(1, 0, 1, 0)
    hit.BackgroundTransparency = 1
    hit.Image              = ""
    hit.ZIndex             = 8
    hit.Parent             = bg
    hit.MouseButton1Click:Connect(function()
        state = not state
        if state then
            tween(knob,     {Position = UDim2.new(1, -19, 0.5, -8)}, 0.2, Enum.EasingStyle.Back)
            tween(bg,       {BackgroundColor3 = T.purple2}, 0.18)
            tween(bgStroke, {Color = T.purple2}, 0.18)
            tween(knobGlow, {Color = T.accentGlow}, 0.18)
            bgGradInst.Color = ColorSequence.new(T.purple1, T.purple3)
        else
            tween(knob,     {Position = UDim2.new(0, 3, 0.5, -8)}, 0.2, Enum.EasingStyle.Back)
            tween(bg,       {BackgroundColor3 = T.cardInner}, 0.18)
            tween(bgStroke, {Color = T.border}, 0.18)
            tween(knobGlow, {Color = T.textDim}, 0.18)
            bgGradInst.Color = ColorSequence.new(T.cardInner, T.cardInner)
        end
        if cb then cb(state) end
    end)
    local api = {}
    function api.setState(newState, skipCallback)
        state = newState
        if state then
            tween(knob,     {Position = UDim2.new(1, -19, 0.5, -8)}, 0.2, Enum.EasingStyle.Back)
            tween(bg,       {BackgroundColor3 = T.purple2}, 0.18)
            tween(bgStroke, {Color = T.purple2}, 0.18)
            tween(knobGlow, {Color = T.accentGlow}, 0.18)
            bgGradInst.Color = ColorSequence.new(T.purple1, T.purple3)
        else
            tween(knob,     {Position = UDim2.new(0, 3, 0.5, -8)}, 0.2, Enum.EasingStyle.Back)
            tween(bg,       {BackgroundColor3 = T.cardInner}, 0.18)
            tween(bgStroke, {Color = T.border}, 0.18)
            tween(knobGlow, {Color = T.textDim}, 0.18)
            bgGradInst.Color = ColorSequence.new(T.cardInner, T.cardInner)
        end
        if cb and not skipCallback then cb(state) end
    end
    return row, api
end

