-- Mobile-friendly input handling with debounce
local _minBtnDebounce = false
local _minBtnLastClick = 0
local MIN_BTN_COOLDOWN = 0.4  -- Prevent double-clicks

BtnMin.InputBegan:Connect(function(input)
    local now = os.clock()
    -- Accept both mouse clicks and touch inputs
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or 
        input.UserInputType == Enum.UserInputType.Touch) then
        
        -- Debounce to prevent double-triggers
        if _minBtnDebounce or (now - _minBtnLastClick) < MIN_BTN_COOLDOWN then
            return
        end
        
        _minBtnDebounce = true
        _minBtnLastClick = now
        
        -- Visual feedback for touch
        tween(BtnMin, {BackgroundColor3 = Color3.fromRGB(8, 28, 38)}, 0.08)
        
        -- Execute minimize
        doMinimise()
        
        -- Reset debounce after animation
        task.delay(0.15, function()
            tween(BtnMin, {BackgroundColor3 = Color3.fromRGB(14, 44, 56)}, 0.12)
            _minBtnDebounce = false
        end)
    end
end)

