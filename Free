local function mkSlider(parent, text, minV, maxV, defV, unit, order, cb)
    local wrap = Instance.new("Frame")
    wrap.Size = UDim2.new(1, 0, 0, 44); wrap.BackgroundTransparency = 1
    wrap.LayoutOrder = order or 99; wrap.ZIndex = 5; wrap.Parent = parent
    local top = Instance.new("Frame")
