local function updateScanDisplay()
    local ready, growing = scanSaplings()
    readyBadgeL.Text = "Ready: "   .. #ready
    growBadgeL.Text  = "Growing: " .. #growing
    if #ready > 0 then
        local lines = {}
        for i, s in ipairs(ready) do
            if i <= 5 then table.insert(lines, "("..s.x..","..s.y..") "..s.name.." ×"..s.fruits) end
        end
        if #ready > 5 then table.insert(lines, "  + "..( #ready-5).." more...") end
        readyList.Text = table.concat(lines, "\n")
    else readyList.Text = "No saplings ready" end
    if #growing > 0 then
        local lines = {}
        for i, s in ipairs(growing) do
            if i <= 5 then
                table.insert(lines, "("..s.x..","..s.y..") "..s.name.."  "..math.floor(s.progress*100).."%  ("..math.floor(s.timeLeft).."s)")
            end
        end
        if #growing > 5 then table.insert(lines, "  + "..( #growing-5).." more...") end
        growList.Text = table.concat(lines, "\n")
    else growList.Text = "No saplings growing" end
    _G.SaplingsReady   = ready
    _G.SaplingsGrowing = growing
end

local function updateDropsDisplay()
    local dropCount, gemCount = 0, 0
    local dropsByCoord = {}
    for _, drop in pairs(workspace.Drops:GetChildren()) do
        if drop and drop.Parent then
            dropCount = dropCount + 1
            local x = math.round(drop.Position.X / TILE_SIZE)
            local y = math.round(drop.Position.Y / TILE_SIZE)
            local k = x..","..y
            dropsByCoord[k] = (dropsByCoord[k] or 0) + 1
        end
    end
    local dropsList = {}
    for coord, count in pairs(dropsByCoord) do
        local x, y = coord:match("([^,]+),([^,]+)")
        table.insert(dropsList, (count==1 and "Item at" or count.." items at").." ("..x..", "..y..")")
    end
    table.sort(dropsList)
    local gemsFolder = workspace:FindFirstChild("Gems")
    if gemsFolder then
        for _, gem in pairs(gemsFolder:GetChildren()) do
            if gem:IsA("BasePart") and gem:FindFirstChild("gems") then gemCount = gemCount + 1 end
        end
    end
    dropsBadgeL.Text  = "Drops: " .. dropCount
    gemsBadgeL.Text   = "Gems: "  .. gemCount
    dropsListLbl.Text = #dropsList > 0 and table.concat(dropsList, "\n") or "No drops in world"
end

