local function updateMinimap()
    local minX   = _G.MinX   or 0
    local maxX   = _G.MaxX   or 50
    local startY = _G.StartY or 0
    local endY   = _G.EndY   or 20
    local centerX    = (minX + maxX) / 2
    local centerY    = (startY + endY) / 2
    local farmWidth  = (maxX - minX) * TILE_SIZE
    local farmHeight = (endY - startY) * TILE_SIZE
    local fov     = 10
    local fovRad  = math.rad(fov / 2)
    local vAspect = 1.33
    local distH   = farmHeight / (2 * math.tan(fovRad))
    local distW   = farmWidth  / (2 * math.tan(fovRad) * vAspect)
    local distance = math.max(distH, distW) * 1.1
    local maxDim   = math.max(farmWidth, farmHeight)
    minimapCamera.CFrame = CFrame.new(centerX*TILE_SIZE, centerY*TILE_SIZE, distance)
    local markerSize = math.max(TILE_SIZE*0.6, maxDim*0.04)
    playerMarker.Size = Vector3.new(markerSize, markerSize, markerSize)
    if movement and movement.Position then
        playerMarker.Position = Vector3.new(movement.Position.X, movement.Position.Y, 1)
    end
    for _, child in ipairs(viewport:GetChildren()) do
        if child:IsA("Part") and child ~= playerMarker then child:Destroy() end
    end
    for x = minX, maxX do
        for y = startY, endY do
            local tileId   = WorldManager.GetTile(x, y, 1)
            local tilePart = Instance.new("Part")
            tilePart.Size     = Vector3.new(TILE_SIZE*0.9, TILE_SIZE*0.9, 0.5)
            tilePart.Position = Vector3.new(x*TILE_SIZE, y*TILE_SIZE, 0)
            tilePart.Anchored = true
            if tileId and isSapling(tileId) then
                tilePart.Color = Color3.fromRGB(80, 210, 130)
            elseif tileId then
                tilePart.Color = Color3.fromRGB(50, 150, 170)
            else
                tilePart.Color       = Color3.fromRGB(8, 20, 26)
                tilePart.Transparency = 0.4
            end
            tilePart.Parent = viewport
        end
    end
end

local function scanSaplings()
    local worldMin = workspace:GetAttribute("WorldMin")
    local worldMax = workspace:GetAttribute("WorldMax")
    local minX = worldMin and worldMin.X or 0
    local maxX = worldMax and worldMax.X or 120
    local minY = worldMin and worldMin.Y or 0
    local maxY = worldMax and worldMax.Y or 70
    local ready, growing = {}, {}
    for x = minX, maxX do
        for y = minY, maxY do
            local tileId, tileData = WorldManager.GetTile(x, y, 1)
            if tileId and isSapling(tileId) and tileData then
                local itemData = ItemsManager.RequestItemData(tileId)
                if itemData then
                    local plantTime = tileData.at or 0
                    local fruits    = tileData.n  or 0
                    local rarity    = itemData.Rarity or 1
                    local growTime  = getGrowTime(rarity)
                    local elapsed   = workspace:GetServerTimeNow() - plantTime
                    local progress  = math.clamp(elapsed / growTime, 0, 1)
                    local info      = {x=x, y=y, name=itemData.Name, fruits=fruits, progress=progress, timeLeft=math.max(0,growTime-elapsed)}
                    if progress >= 1 then table.insert(ready, info) else table.insert(growing, info) end
                end
            end
        end
    end
    return ready, growing
end

