local function switchTab(idx)
    currentTab = idx
    for i, btn in ipairs(tabBtns) do
        local on = (i == idx)
        if on then
            tween(btn, {BackgroundColor3 = T.purpleDim, TextColor3 = T.accent}, 0.15)
            tabLines[i].Visible = true
        else
            tween(btn, {BackgroundColor3 = Color3.fromRGB(0,0,0), TextColor3 = T.textDim}, 0.15)
            tabLines[i].Visible = false
            btn.BackgroundTransparency = 1
