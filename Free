local isSapling       = Hub.isSapling
local TILE_SIZE       = Hub.TILE_SIZE       or 4.5
local WORLD_W         = Hub.WORLD_W         or 120
local WORLD_H         = Hub.WORLD_H         or 70
local MOVE_DELAY      = Hub.MOVE_DELAY      or 0.08
local ASTAR_MAX_NODES = Hub.ASTAR_MAX_NODES or 2000

-- ─────────────────────────────────────────────────────────────
-- STATE
