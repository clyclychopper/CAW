local function safeIsFile(path)
    local ok,result=pcall(function() return isfile and isfile(path) end); return ok and result
end
local function safeReadFile(path)
    local ok,result=pcall(function() return readfile and readfile(path) end)
    if ok then return result end; return nil
end
local function safeWriteFile(path, data)
    pcall(function()
        if makefolder and not (isfolder and isfolder(CONFIG_FOLDER)) then
            pcall(function() makefolder(CONFIG_FOLDER) end)
        end
        if writefile then writefile(path, data) end
    end)
end
local function loadConfigsFromFile()
    if not safeIsFile(CONFIG_FILE) then return nil end
    local raw=safeReadFile(CONFIG_FILE); if not raw then return nil end
    local ok,data=pcall(function() return HttpService:JSONDecode(raw) end)
    if ok then return data end; return nil
end
local function saveConfigsToFile()
    local ok,encoded=pcall(function() return HttpService:JSONEncode(_G.KiroConfigs) end)
    if ok then safeWriteFile(CONFIG_FILE,encoded) end
end

