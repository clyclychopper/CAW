local function mkDropdown(parent, items, order, cb, label, placeholder)
    local ITEM_H = 28
    local wrap = Instance.new("Frame")
    wrap.Size             = UDim2.new(1, 0, 0, 30)
    wrap.BackgroundTransparency = 1
    wrap.LayoutOrder      = order or 99
    wrap.ClipsDescendants = false
    wrap.ZIndex           = 5
    wrap.Parent           = parent
    mkRowLabel(wrap, label or "Select")
    local btnBg = Instance.new("Frame")
    btnBg.Size             = UDim2.new(0, 158, 0, 26)
    btnBg.Position         = UDim2.new(1, -158, 0.5, -13)
    btnBg.BackgroundColor3 = T.cardInner
    btnBg.BorderSizePixel  = 0
    btnBg.ZIndex           = 6
    btnBg.Parent           = wrap
    corner(btnBg, 7)
    local btnStroke = stroke(btnBg, T.border, 1)
    local btnLbl = Instance.new("TextLabel")
    btnLbl.Size              = UDim2.new(1, -24, 1, 0)
    btnLbl.Position          = UDim2.new(0, 8, 0, 0)
    btnLbl.BackgroundTransparency = 1
    btnLbl.Text              = placeholder or "Select..."
    btnLbl.TextColor3        = T.textDim
    btnLbl.TextSize          = 13
    btnLbl.Font              = Enum.Font.GothamBold
    btnLbl.TextXAlignment    = Enum.TextXAlignment.Left
    btnLbl.TextTruncate      = Enum.TextTruncate.AtEnd
    btnLbl.ZIndex            = 7
    btnLbl.Parent            = btnBg
            local arrow = Instance.new("TextLabel")
    arrow.Size             = UDim2.new(0, 20, 1, 0)
    arrow.Position         = UDim2.new(1, -22, 0, -2)
    arrow.BackgroundTransparency = 1
    arrow.Text             = "v"
    arrow.TextColor3       = T.textDim
    arrow.TextSize         = 14
    arrow.Font             = Enum.Font.GothamBold
    arrow.TextYAlignment   = Enum.TextYAlignment.Center
    arrow.ZIndex           = 7
    arrow.Parent           = btnBg
    local list = Instance.new("Frame")
    list.BackgroundColor3  = Color3.fromRGB(20, 14, 42)
    list.BorderSizePixel   = 0
    list.Visible           = false
    list.ZIndex            = 60
    list.Size              = UDim2.new(0, 158, 0, 0)
    list.Parent            = Gui
    corner(list, 8)
    stroke(list, T.purple1, 1)
    local listGrad = Instance.new("UIGradient")
    listGrad.Color    = ColorSequence.new(Color3.fromRGB(14,42,54), Color3.fromRGB(8,24,32))
    listGrad.Rotation = 90
    listGrad.Parent   = list
    local ll = Instance.new("UIListLayout")
    ll.Padding  = UDim.new(0, 1)
    ll.Parent   = list
    local lp = Instance.new("UIPadding")
    lp.PaddingTop    = UDim.new(0, 4)
    lp.PaddingBottom = UDim.new(0, 4)
    lp.Parent = list
    local isOpen, selected = false, nil
    local function close(instant)
        isOpen = false
        if instant then
            list.Size = UDim2.new(0, 158, 0, 0); list.Visible = false; arrow.Rotation = 0
        else
            tween(list,  {Size = UDim2.new(0, 158, 0, 0)}, 0.14, Enum.EasingStyle.Quart)
            tween(arrow, {Rotation = 0, TextColor3 = T.textDim}, 0.14)
            tween(btnStroke, {Color = T.border}, 0.14)
            task.delay(0.15, function() list.Visible = false end)
        end
        for i, f in ipairs(activeDropdowns) do
            if f == close then table.remove(activeDropdowns, i); break end
        end
    end
    local function open()
        local abs = btnBg.AbsolutePosition
        local sz  = btnBg.AbsoluteSize
        local cnt = math.min(#(items or {}), 6)
        list.Position = UDim2.new(0, abs.X, 0, abs.Y + sz.Y + 4)
        list.Size     = UDim2.new(0, 158, 0, 0)
        list.Visible  = true
        isOpen        = true
        tween(list,  {Size = UDim2.new(0, 158, 0, cnt * ITEM_H + 8)}, 0.18, Enum.EasingStyle.Back)
        tween(arrow, {Rotation = 180, TextColor3 = T.accent}, 0.14)
        tween(btnStroke, {Color = T.purple2}, 0.14)
        if not table.find(activeDropdowns, close) then table.insert(activeDropdowns, close) end
    end
    local function populate(its)
        for _, c in ipairs(list:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for i, item in ipairs(its) do
            local opt = Instance.new("TextButton")
            opt.Size             = UDim2.new(1, 0, 0, ITEM_H)
            opt.BackgroundColor3 = Color3.fromRGB(12,36,46)
            opt.BackgroundTransparency = 0
            opt.Text             = item
            opt.TextColor3       = T.textSub
            opt.TextSize         = 13
            opt.Font             = Enum.Font.GothamBold
            opt.TextXAlignment   = Enum.TextXAlignment.Left
            opt.ZIndex           = 61
            opt.Parent           = list
            local op = Instance.new("UIPadding")
            op.PaddingLeft = UDim.new(0, 10)
            op.Parent = opt
            local hoverLine = Instance.new("Frame")
            hoverLine.Size             = UDim2.new(0, 2, 0.6, 0)
            hoverLine.Position         = UDim2.new(0, 0, 0.2, 0)
            hoverLine.BackgroundColor3 = T.purple2
            hoverLine.BackgroundTransparency = 1
            hoverLine.BorderSizePixel  = 0
            hoverLine.ZIndex           = 62
            hoverLine.Parent           = opt
            opt.MouseEnter:Connect(function() tween(opt, {BackgroundColor3=T.cardHover, TextColor3=T.textMain}, 0.1); tween(hoverLine, {BackgroundTransparency=0}, 0.1) end)
            opt.MouseLeave:Connect(function() tween(opt, {BackgroundColor3=Color3.fromRGB(12,36,46), TextColor3=T.textSub}, 0.1); tween(hoverLine, {BackgroundTransparency=1}, 0.1) end)
            opt.MouseButton1Click:Connect(function()
                selected = item; btnLbl.Text = item; btnLbl.TextColor3 = T.textMain
                close(); if cb then cb(item) end
            end)
        end
    end
    local hit = Instance.new("ImageButton")
    hit.Size               = UDim2.new(1, 0, 1, 0)
    hit.BackgroundTransparency = 1
    hit.Image              = ""
    hit.ZIndex             = 8
    hit.Parent             = btnBg
    hit.MouseButton1Click:Connect(function() if isOpen then close() else open() end end)
    local function isOverDropdown(mousePos)
        local bPos, bSz = btnBg.AbsolutePosition, btnBg.AbsoluteSize
        local lPos, lSz = list.AbsolutePosition,  list.AbsoluteSize
        if mousePos.X>=bPos.X and mousePos.X<=bPos.X+bSz.X and mousePos.Y>=bPos.Y and mousePos.Y<=bPos.Y+bSz.Y then return true end
        if list.Visible and mousePos.X>=lPos.X and mousePos.X<=lPos.X+lSz.X and mousePos.Y>=lPos.Y and mousePos.Y<=lPos.Y+lSz.Y then return true end
        return false
    end
    UserInputService.InputBegan:Connect(function(i)
        if isOpen and i.UserInputType == Enum.UserInputType.MouseButton1 then
            if not isOverDropdown(i.Position) then close() end
        end
    end)
    if items then populate(items) end
    local api = {}
    function api.setItems(its)      items = its; populate(its) end
    function api.getSelected()      return selected end
    function api.setDisplayText(t)  btnLbl.Text = t; btnLbl.TextColor3 = T.textMain end
    return wrap, api
end

