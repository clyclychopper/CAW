local function updateInventoryDisplay()
    if not Inventory or not Inventory.MaxSlots then
        for id, cached in pairs(_invRowCache) do pcall(function() cached.row:Destroy() end) end
        _invRowCache = {}
        for _, child in ipairs(invScroll:GetChildren()) do
            if child:IsA("GuiObject") and child.Name=="InvItem" then child:Destroy() end
        end
        local lbl=Instance.new("TextLabel"); lbl.Name="InvItem"; lbl.Size=UDim2.new(1,0,0,40)
        lbl.BackgroundTransparency=1; lbl.Text="Inventory not available"; lbl.TextColor3=T.textDim
        lbl.TextSize=13; lbl.Font=Enum.Font.GothamBold; lbl.Parent=invScroll
        slotBadgeL.Text="Slots: N/A"; return
    end
    local usedSlots=0
    for slot=1,Inventory.MaxSlots do if Inventory.Stacks[slot] and Inventory.Stacks[slot].Id then usedSlots=usedSlots+1 end end
    slotBadgeL.Text="Slots: "..usedSlots.."/"..Inventory.MaxSlots
    local itemGroups={}
    for slot=1,Inventory.MaxSlots do
        local stack=Inventory.Stacks[slot]
        if stack and stack.Id then
            if not itemGroups[stack.Id] then itemGroups[stack.Id]={id=stack.Id,amount=0,slots={}} end
            itemGroups[stack.Id].amount=itemGroups[stack.Id].amount+(stack.Amount or 1)
            table.insert(itemGroups[stack.Id].slots,slot)
        end
    end
    for id, cached in pairs(_invRowCache) do
        if not itemGroups[id] then
            pcall(function() cached.row:Destroy() end); _invRowCache[id]=nil
        end
    end
    local itemList={}
    for id,data in pairs(itemGroups) do table.insert(itemList,data) end
    table.sort(itemList,function(a,b) return a.id<b.id end)
    if #itemList==0 then
        for _, child in ipairs(invScroll:GetChildren()) do
            if child:IsA("GuiObject") and child.Name=="InvItem" then child:Destroy() end
        end
        _invRowCache={}
        local lbl=Instance.new("TextLabel"); lbl.Name="InvItem"; lbl.Size=UDim2.new(1,0,0,40)
        lbl.BackgroundTransparency=1; lbl.Text="Inventory is empty"; lbl.TextColor3=T.textDim
        lbl.TextSize=13; lbl.Font=Enum.Font.GothamBold; lbl.Parent=invScroll; return
    end
    for _, item in ipairs(itemList) do
        if _invRowCache[item.id] then
            local c = _invRowCache[item.id]
            c.amtLbl.Text = "x"..item.amount
            local isSel = _G.SelectedInventoryItems[item.id]
            c.checkMark.Text              = isSel and "✓" or ""
            c.checkBg.BackgroundColor3    = isSel and T.purpleDim  or T.cardInner
            c.checkStroke.Color           = isSel and T.accent     or T.border
        else
            _invRowCache[item.id] = _buildInvRow(item, itemGroups)
        end
    end
end

